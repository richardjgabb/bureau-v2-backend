{
    "require": {
        "ext-pdo": "*",
        "php-di/php-di": "^7.0",
        "slim/http": "^1.4",
        "slim/php-view": "^3.4",
        "slim/psr7": "^1.7",
        "slim/slim": "^4.14",
        "symfony/console": "^8.0",
        "symfony/event-dispatcher": "^7.4",
        "vlucas/phpdotenv": "^5.6"
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    },
    "config": {
        "process-timeout": 0,
        "sort-packages": true
    },
    "scripts": {
        "start": "php -S 0.0.0.0:8080 -t public",
        "test": "phpunit",
        "seed": "php bin/console db:seed",
        "make:controller": "php bin/console make:controller",
        "make:repository": "php bin/console make:repository",
        "make:service": "php bin/console make:service",
        "make:DTO": "php bin/console make:DTO"
    }
}
